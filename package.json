{
  "name": "supercrew-kanban",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"pnpm run dev:backend\" \"pnpm run dev:frontend\"",
    "dev:backend": "cd backend && bun run src/index.ts",
    "dev:frontend": "cd frontend/packages/local-web && pnpm dev",
    "typecheck": "cd backend && pnpm run typecheck"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@types/node": "^25.3.3",
    "hono": "^4.12.3"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
