# GitHub OAuth App credentials
# Create at: https://github.com/settings/developers → New OAuth App
# Callback URL should be: http://localhost:3001/auth/callback (dev)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# GitHub Personal Access Token (for testing and validation)
# Required for running validation tests against GitHub API
# Quick setup: GITHUB_TOKEN=$(gh auth token) bun test
# Or create a PAT at: https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_your_personal_access_token

# Turso Database credentials
# For production:
#   turso db show supercrew-kanban --url
#   turso db tokens create supercrew-kanban
# For local development:
#   turso dev --db-file ./dev.db
#   Use: http://127.0.0.1:8080 and token: dev-token
TURSO_DATABASE_URL=http://127.0.0.1:8080
TURSO_AUTH_TOKEN=dev-token

# Vercel Cron Job secret (production only)
# Generate with: openssl rand -hex 32
CRON_SECRET=your_cron_secret

# Frontend URL (used for CORS and OAuth redirects)
FRONTEND_URL=http://localhost:5173

# Backend URL (used for OAuth callback)
BACKEND_URL=http://localhost:3001

# Backend port
PORT=3001
