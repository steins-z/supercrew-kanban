# Environment Variables Template
# Copy this file to .env.local for local development

# Backend API URL (default: http://localhost:3001)
# VITE_BACKEND_URL=http://localhost:3001

# Development mode (optional, only for local development)
# Set to 'local-git' to bypass GitHub API and use local git repository
# Leave unset or remove this line for production builds
# VITE_DEV_MODE=local-git

# Local repository path (only used when VITE_DEV_MODE=local-git)
# Windows example: d:\repo\supercrew-kanban
# Mac/Linux example: /Users/you/projects/my-project
# Leave empty to use backend's current working directory
# VITE_REPO_PATH=
