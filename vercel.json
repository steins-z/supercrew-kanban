{
  "buildCommand": "pnpm --filter @vibe/local-web build",
  "outputDirectory": "frontend/packages/local-web/dist",
  "installCommand": "corepack enable && pnpm install",
  "crons": [
    {
      "path": "/api/cron/validate",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/reconcile",
      "schedule": "0 3 * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/auth/github", "destination": "/api" },
    { "source": "/auth/callback", "destination": "/api" },
    { "source": "/health", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
