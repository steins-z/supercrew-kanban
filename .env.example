# Required — GitHub OAuth App credentials
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Required — Turso Database credentials
# Get these by running:
#   turso db show supercrew-kanban --url
#   turso db tokens create supercrew-kanban
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Optional — Vercel Cron Job authentication
# Generate a random secret for production:
#   openssl rand -hex 32
CRON_SECRET=

# Optional — defaults shown
# FRONTEND_URL=http://localhost:5173
# BACKEND_URL=http://localhost:3001
# PORT=3001
